#!/usr/bin/env ruby
# kiri 霧 — terminal CSV manager

require 'net/http'
require 'uri'
require 'json'

begin; require 'tty-table'; HAS_TTY    = true; rescue LoadError; HAS_TTY    = false; end
begin; require 'pastel';    HAS_PASTEL = true; rescue LoadError; HAS_PASTEL = false; end

# ── config ─────────────────────────────────────────────────────────────────────

HOST  = ENV.fetch('CSV_API_HOST', 'http://localhost:7777')
COLOR = HAS_PASTEL && $stdout.tty?
P     = COLOR ? Pastel.new : nil

# ── output helpers ─────────────────────────────────────────────────────────────

def c(text, *styles)
  return text.to_s unless COLOR
  P.decorate(text.to_s, *styles)
end

def ok(msg);   puts("#{c('✓', :green, :bold)} #{msg}"); end
def err(msg);  warn("#{c('✗', :red,   :bold)} #{msg}"); exit 1; end
def info(msg); puts("#{c('▸', :yellow, :bold)} #{c(msg, :bold)}"); end

def render_table(headers, rows)
  return puts(c('( empty )', :dim)) if rows.empty?

  if HAS_TTY
    idx_headers = [c('#', :cyan, :bold), *headers.map { |h| c(h, :cyan, :bold) }]
    idx_rows    = rows.each_with_index.map { |r, i| [c(i, :dim), *r] }
    puts TTY::Table.new(header: idx_headers, rows: idx_rows)
              .render(:unicode, padding: [0, 1])
  else
    all    = [['#', *headers], *rows.each_with_index.map { |r, i| [i.to_s, *r] }]
    widths = all.transpose.map { |col| col.map { |v| v.to_s.length }.max }
    all.each_with_index do |row, i|
      line = row.each_with_index.map { |v, j| v.to_s.ljust(widths[j]) }.join('  ')
      puts i == 0 ? c(line, :bold) : line
    end
  end
end

# ── HTTP ───────────────────────────────────────────────────────────────────────

def http_req(method, path, params = nil)
  uri  = URI("#{HOST}#{path}")
  http = Net::HTTP.new(uri.host, uri.port)
  klass = { get: Net::HTTP::Get, post: Net::HTTP::Post,
            put: Net::HTTP::Put, delete: Net::HTTP::Delete }[method]
  req = klass.new(uri)
  req['User-Agent'] = 'kiri-cli/2.0'
  if params
    req['Content-Type'] = 'application/x-www-form-urlencoded'
    req.body = URI.encode_www_form(params)
  end
  res = http.request(req)
  err res.body.strip if res.code.to_i >= 400
  res.body
rescue Errno::ECONNREFUSED
  err "Cannot connect to #{HOST} — is the server running?"
end

def get_json(path)
  uri = URI("#{HOST}#{path}")
  req = Net::HTTP::Get.new(uri)
  req['Accept']     = 'application/json'
  req['User-Agent'] = 'kiri-cli/2.0'
  JSON.parse(Net::HTTP.new(uri.host, uri.port).request(req).body)
rescue Errno::ECONNREFUSED
  err "Cannot connect to #{HOST} — is the server running?"
rescue JSON::ParserError => e
  err "Invalid JSON response: #{e.message}"
end

# ── data helpers ───────────────────────────────────────────────────────────────

def strip_id(data)
  return [[], []] if data.empty?
  headers = data.first.keys.reject { |k| k == '_id' }
  rows    = data.map { |r| r.values_at(*headers) }
  [headers, rows]
end

def parse_pairs(pairs)
  pairs.each_with_object({}) do |pair, h|
    k, v = pair.split('=', 2)
    err "Invalid pair '#{pair}' — use col=value format" unless k && v
    h[k] = v
  end
end

# ── commands ───────────────────────────────────────────────────────────────────

def cmd_ls
  data = get_json('/')
  info "Tables on #{HOST}"
  data.each { |t| puts "  #{c(t, :cyan)}" }
end

def cmd_show(table, json_mode)
  data = get_json("/#{table}")
  return puts(JSON.pretty_generate(data)) if json_mode
  info table
  render_table(*strip_id(data))
end

def cmd_get(table, id, json_mode)
  data = get_json("/#{table}/#{id}")
  return puts(JSON.pretty_generate(data)) if json_mode
  info "#{table} / row #{id}"
  render_table(*strip_id(data))
end

def cmd_add(table, pairs)
  ok http_req(:post, "/#{table}", parse_pairs(pairs)).strip
end

def cmd_set(table, id, pairs)
  ok http_req(:put, "/#{table}/#{id}", parse_pairs(pairs)).strip
end

def cmd_rm(table, id)
  ok http_req(:delete, "/#{table}/#{id}").strip
end

def cmd_new(table, cols_str)
  ok http_req(:post, "/#{table}/create", { 'headers' => cols_str }).strip
end

def cmd_cols(table)
  data = get_json("/#{table}")
  cols = data.first&.keys&.reject { |k| k == '_id' } || []
  info "Columns in #{table}"
  puts cols.map { |col| "  #{c(col, :cyan)}" }.join("\n")
end

def cmd_grep(table, col, val)
  data = get_json("/#{table}")
  err "Table '#{table}' is empty" if data.empty?
  available = data.first.keys.reject { |k| k == '_id' }
  err "Column '#{col}' not found. Available: #{available.join(', ')}" unless available.include?(col)
  filtered = data.select { |r| r[col].to_s.downcase.include?(val.downcase) }
  info "#{table} where #{col} ~ '#{val}'"
  err "No matching rows." if filtered.empty?
  render_table(*strip_id(filtered))
end

# ── diet commands ──────────────────────────────────────────────────────────────

MEALS_TABLE = 'meals'
GOALS_TABLE = 'diet_goals'
MEALS_COLS  = 'date,food,kcal,protein_g,carbs_g,fat_g'
GOALS_COLS  = 'kcal,protein_g,carbs_g,fat_g'
MACROS      = %w[kcal protein_g carbs_g fat_g].freeze

def diet_ensure_tables
  tables = get_json('/')
  http_req(:post, "/#{MEALS_TABLE}/create", { 'headers' => MEALS_COLS }) unless tables.include?(MEALS_TABLE)
  http_req(:post, "/#{GOALS_TABLE}/create", { 'headers' => GOALS_COLS }) unless tables.include?(GOALS_TABLE)
end

def diet_get_goals
  get_json("/#{GOALS_TABLE}").first
end

def diet_today_meals
  today = Time.now.strftime('%Y-%m-%d')
  get_json("/#{MEALS_TABLE}").select { |r| r['date'] == today }
end

def diet_sum(meals)
  MACROS.each_with_object({}) do |col, h|
    h[col] = meals.sum { |r| r[col].to_f }.round(1)
  end
end

def diet_bar(current, goal, width = 20)
  return '' unless goal && goal.to_f > 0
  pct    = [current.to_f / goal.to_f, 1.0].min
  filled = (pct * width).round
  bar    = c('█' * filled, pct < 0.85 ? :green : pct < 1.0 ? :yellow : :red)
  "#{bar}#{c('░' * (width - filled), :dim)} #{(pct * 100).round}%"
end

def cmd_diet(subcmd, args)
  diet_ensure_tables

  case subcmd

  when 'init'
    ok "Diet tables ready: #{MEALS_TABLE}, #{GOALS_TABLE}"

  when 'log'
    food = args.shift
    err "Usage: kiri diet log <food> kcal=X protein_g=X carbs_g=X fat_g=X" unless food
    pairs         = parse_pairs(args)
    pairs['date'] = Time.now.strftime('%Y-%m-%d')
    pairs['food'] = food
    ok http_req(:post, "/#{MEALS_TABLE}", pairs).strip

  when 'today'
    today  = Time.now.strftime('%Y-%m-%d')
    meals  = diet_today_meals
    totals = diet_sum(meals)
    goals  = diet_get_goals

    info "#{today} — meals"
    if meals.empty?
      puts c('  ( no meals logged today )', :dim)
    else
      cols = %w[food kcal protein_g carbs_g fat_g]
      render_table(cols, meals.map { |m| m.values_at(*cols) })
    end

    puts
    info 'daily totals'
    MACROS.each do |col|
      cur      = totals[col]
      goal     = goals ? goals[col].to_f : nil
      goal_str = goal ? "/ #{goal}" : '/ --'
      puts "  #{c(col.ljust(10), :cyan)}  #{cur.to_s.rjust(7)} #{goal_str.ljust(10)}  #{diet_bar(cur, goal)}"
    end

  when 'goal'
    sub2 = args.shift
    case sub2
    when 'set'
      err "Usage: kiri diet goal set kcal=X protein_g=X carbs_g=X fat_g=X" if args.empty?
      pairs = parse_pairs(args)
      data  = get_json("/#{GOALS_TABLE}")
      if data.empty?
        ok http_req(:post, "/#{GOALS_TABLE}", pairs).strip
      else
        ok http_req(:put, "/#{GOALS_TABLE}/0", pairs).strip
      end
    when 'show', nil
      goals = diet_get_goals
      err "No goals set — run: kiri diet goal set kcal=2000 protein_g=150 carbs_g=200 fat_g=70" unless goals
      info 'daily goals'
      MACROS.each { |col| puts "  #{c(col.ljust(10), :cyan)}  #{goals[col]}" }
    else
      err "Usage: kiri diet goal [set|show]"
    end

  when 'chart'
    err "youplot not installed — run: gem install youplot" unless system('which uplot > /dev/null 2>&1')
    macro = args.shift || 'kcal'
    days  = (args.shift || '7').to_i
    err "Unknown macro '#{macro}'. Use: #{MACROS.join(', ')}" unless MACROS.include?(macro)

    data = get_json("/#{MEALS_TABLE}")
    err "No meals logged yet" if data.empty?

    by_date = data.group_by { |r| r['date'] }
    dates   = by_date.keys.sort.last(days)
    points  = dates.map { |d| [d, by_date[d].sum { |r| r[macro].to_f }.round(1)] }

    info "#{macro} — last #{days} days"
    IO.popen(['uplot', 'bar', '-H', '-t', "#{macro} / day"], 'w') do |io|
      io.puts "date\t#{macro}"
      points.each { |d, v| io.puts "#{d}\t#{v}" }
    end

  else
    puts <<~USAGE
      #{c('kiri diet', :cyan, :bold)} — dietary tracker

        kiri diet init                              create meals & goals tables
        kiri diet log <food> kcal=X protein_g=X …  log a meal (today's date auto-set)
        kiri diet today                             show today's meals + totals vs goals
        kiri diet goal set kcal=X protein_g=X …    set daily macro goals
        kiri diet goal show                         show current goals
        kiri diet chart [macro] [days]              bar chart (default: kcal, 7 days)

      Macros: #{MACROS.join(', ')}
    USAGE
  end
end

def cmd_chart(table, col, type)
  err "youplot not installed — run: gem install youplot" unless system('which uplot > /dev/null 2>&1')
  data = get_json("/#{table}")
  err "Table '#{table}' is empty" if data.empty?
  available = data.first.keys.reject { |k| k == '_id' }
  err "Column '#{col}' not found. Available: #{available.join(', ')}" unless available.include?(col)

  values  = data.map { |r| r[col] }
  numeric = values.compact.all? { |v| v.to_s =~ /\A-?\d+(\.\d+)?\z/ }

  if !numeric
    # text column: always use count bar regardless of requested type
    warn "#{c('!', :yellow, :bold)} '#{col}' is text — showing count bar" if type != 'bar'
    info "#{table} / #{col} (count)"
    counts = values.compact.tally
    IO.popen(['uplot', 'bar', '-H', '-t', "#{table} — #{col} (count)"], 'w') do |io|
      io.puts "#{col}\tcount"
      counts.each { |v, n| io.puts "#{v}\t#{n}" }
    end
  else
    info "#{table} / #{col} (#{type})"
    IO.popen(['uplot', type, '-H', '-t', "#{table} — #{col}"], 'w') do |io|
      io.puts col
      values.each { |v| io.puts v }
    end
  end
end

# ── usage ──────────────────────────────────────────────────────────────────────

USAGE = <<~USAGE
